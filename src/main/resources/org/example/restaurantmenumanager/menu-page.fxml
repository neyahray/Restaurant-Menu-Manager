<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="root" prefHeight="1120.0" prefWidth="1960.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.restaurantmenumanager.MenuController">
<padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
</padding>
<ImageView fitHeight="1120" fitWidth="1960" opacity="0.25" preserveRatio="false">
    <Image url="@../../../images/pinkFlowerPattern.jpg" />
    <effect>
        <Glow />
    </effect>
</ImageView>
<StackPane fx:id="mainStackPane" prefHeight="150.0" prefWidth="200.0">
      <children>
         <VBox alignment="TOP_CENTER" prefHeight="120.0" prefWidth="200.0">
            <children>
               <Label alignment="TOP_CENTER" contentDisplay="CENTER" text="⋆.୭ MENU ࿔*⭑" textAlignment="CENTER" textFill="#ff8c8c">
                  <font>
                     <Font name="Trebuchet MS Bold" size="70.0" />
                  </font>
                  <effect>
                     <Glow />
                  </effect>
                  <VBox.margin>
                     <Insets bottom="50.0" />
                  </VBox.margin>
               </Label>
               <HBox alignment="TOP_CENTER" prefHeight="0.0" prefWidth="200.0">
                  <children>
                     <Button alignment="CENTER" mnemonicParsing="false" style="-fx-background-radius: 15; -fx-background-color: #a3a380;" text="Pastries" textFill="#fefaf1">
                        <HBox.margin>
                           <Insets right="10.0" />
                        </HBox.margin>
                        <font>
                           <Font name="Trebuchet MS Bold" size="26.0" />
                        </font>
                        <padding>
                           <Insets bottom="15.0" left="230.0" right="230.0" top="15.0" />
                        </padding></Button>
                     <Button mnemonicParsing="false" style="-fx-background-radius: 15; -fx-background-color: #a3a380;" text="Drinks" textFill="#fefaf1">
                        <HBox.margin>
                           <Insets left="10.0" />
                        </HBox.margin>
                        <font>
                           <Font name="Trebuchet MS Bold" size="26.0" />
                        </font>
                        <padding>
                           <Insets bottom="15.0" left="230.0" right="230.0" top="15.0" />
                        </padding></Button>
                  </children>
                  <VBox.margin>
                     <Insets bottom="20.0" />
                  </VBox.margin>
               </HBox>
               <StackPane prefHeight="600.0" prefWidth="200.0" style="-fx-background-radius: 18; -fx-border-radius: 18; -fx-background-color: #d3d4b5;">
                  <children>
                     <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background: transparent;">
                        <content>
                           <VBox fx:id="VBoxPastry">
                              <children>

                              </children>
                           </VBox>
                        </content>
                        <padding>
                           <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                        </padding>
                        <StackPane.margin>
                           <Insets />
                        </StackPane.margin>
                     </ScrollPane>
                     <ScrollPane fitToWidth="true" layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background: transparent;" visible="false">
                        <StackPane.margin>
                           <Insets />
                        </StackPane.margin>
                        <padding>
                           <Insets bottom="10.0" />
                        </padding>
                        <content>
                           <HBox prefHeight="100.0" prefWidth="200.0" />
                        </content>
                     </ScrollPane>
                  </children>
               </StackPane>
            </children>
            <StackPane.margin>
               <Insets bottom="300.0" left="400.0" right="400.0" top="250.0" />
            </StackPane.margin>
         </VBox>
      </children>

</StackPane>

<Button fx:id="goBackButton" ellipsisString="" mnemonicParsing="false" style="-fx-background-color: #fefaf1; -fx-background-radius: 16px;" text="To Main Page" textAlignment="CENTER" textFill="#ff8c8c" StackPane.alignment="TOP_LEFT">
 <font>
     <Font name="Trebuchet MS Bold" size="25.0" />
 </font>
 <padding>
     <Insets bottom="10.0" left="80.0" right="80.0" top="10.0" />
 </padding>
      <effect>
         <Glow />
      </effect>
</Button>
</StackPane>
